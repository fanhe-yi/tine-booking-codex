NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Preferred format: sha256:<salt>:<hex hash of "salt:password">
# You can generate one with:
# node -e "const crypto=require('crypto');const p='change-me';const s=crypto.randomBytes(16).toString('hex');console.log('sha256:'+s+':'+crypto.createHash('sha256').update(s+':'+p).digest('hex'))"
ADMIN_PASSWORD_HASH=sha256:replace-with-salt:replace-with-hash
ADMIN_SESSION_SECRET=replace-with-long-random-secret
ADMIN_PASSWORD=0000

# LINE official account: ear-cleaning channel
SOX_LINE_CHANNEL_ID=replace-with-sox-channel-id
SOX_LINE_CHANNEL_SECRET=replace-with-sox-channel-secret
SOX_LINE_CHANNEL_ACCESS_TOKEN=replace-with-sox-channel-access-token
SOX_LINE_ADMIN_USER_ID=replace-with-sox-admin-user-id
NEXT_PUBLIC_SOX_LIFF_ID=replace-with-sox-liff-id

# LINE official account: kids-reading channel
READING_LINE_CHANNEL_ID=replace-with-reading-channel-id
READING_LINE_CHANNEL_SECRET=replace-with-reading-channel-secret
READING_LINE_CHANNEL_ACCESS_TOKEN=replace-with-reading-channel-access-token
READING_LINE_ADMIN_USER_ID=replace-with-reading-admin-user-id
NEXT_PUBLIC_READING_LIFF_ID=replace-with-reading-liff-id

# Vercel Cron Authorization bearer token
CRON_SECRET=replace-with-long-random-cron-secret
