NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Preferred format: sha256:<salt>:<hex hash of "salt:password">
# You can generate one with:
# node -e "const crypto=require('crypto');const p='change-me';const s=crypto.randomBytes(16).toString('hex');console.log('sha256:'+s+':'+crypto.createHash('sha256').update(s+':'+p).digest('hex'))"
ADMIN_PASSWORD_HASH=sha256:replace-with-salt:replace-with-hash
ADMIN_SESSION_SECRET=replace-with-long-random-secret
ADMIN_PASSWORD=0000
